# ==============================
# RAG service configuration
# File used by: rag/pipeline/config.py, rag/pipeline/llm_clients.py
# ==============================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
GEC_CHAT_MODEL=gpt-4o-mini
GEC_EMBED_MODEL=text-embedding-3-small

# Index/retrieval settings
GEC_REPO_PATH=../Gec_Server_C
GEC_INDEX_PATH=rag/index_store/gec_rag_index
GEC_MAX_CHARS=1500
GEC_OVERLAP_CHARS=200
GEC_RAG_SIMILARITY_THRESHOLD=0.30
