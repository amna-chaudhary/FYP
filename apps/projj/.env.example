# ==============================
# RAG service configuration
# File used by: projj/config.py, projj/llm_clients.py
# ==============================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
GEC_CHAT_MODEL=gpt-4o-mini
GEC_EMBED_MODEL=text-embedding-3-small

# Index/retrieval settings
GEC_REPO_PATH=/absolute/path/to/your/repo/or/projj
GEC_INDEX_PATH=gec_rag_index
GEC_MAX_CHARS=1500
GEC_OVERLAP_CHARS=200
GEC_RAG_SIMILARITY_THRESHOLD=0.30

