# ==============================
# Node router backend configuration
# File used by: projj/backend/server.js and auth modules
# ==============================

# Server
PORT=3000

# Datastore/Auth
MONGO_URI=mongodb://127.0.0.1:27017/gec
JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=*

# Service routing
RAG_SERVICE_URL=http://127.0.0.1:8000
ACTION_BACKEND_URL=http://127.0.0.1:8001
DEFAULT_MARKET_ADDR=0x_your_marketplace_address

# OTP/Trusted device policies
OTP_EXPIRY_MINUTES=10
DEVICE_TRUST_DAYS=30

# Email (required for OTP)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM_NAME=EnergyCert Bot

