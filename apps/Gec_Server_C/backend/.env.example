# ==============================
# OpenAI (agent + fallback responses)
# ==============================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ==============================
# MCP proxy endpoint used by backend/mcp_client.py
# ==============================
MCP_SERVER_URL=http://127.0.0.1:8002/mcp/invoke

# ==============================
# Aptos network
# ==============================
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
APTOS_EXPLORER_NETWORK=testnet

# ==============================
# Move module + default addresses
# ==============================
MODULE_ADDRESS=0x_your_deployed_module_address
CERT_REGISTRY_ADDR=0x_your_registry_address
MARKET_ADDR=0x_your_marketplace_address

# ==============================
# Transaction signer (server wallet)
# ==============================
APTOS_SENDER_ADDRESS=0x_your_sender_wallet_address
APTOS_SENDER_PRIVATE_KEY_HEX=your_sender_private_key_hex_without_quotes
